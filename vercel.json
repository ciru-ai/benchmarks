{
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "npu.ciru.ai"
        }
      ],
      "destination": "/npu/"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "bench.ciru.ai"
        }
      ],
      "destination": "https://llm.ciru.ai/:path*",
      "permanent": true
    }
  ]
}
